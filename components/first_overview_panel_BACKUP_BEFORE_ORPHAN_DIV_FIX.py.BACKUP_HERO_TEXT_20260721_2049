def _num(value: Any, default: Optional[float] = None) -> Optional[float]:
    try:
        if value is None:
            return default
        numeric = float(value)
        if pd.isna(numeric):
            return default
        return numeric
    except Exception:
        return default


def _fmt_money(value: Any, symbol: str = "₺", decimals: Optional[int] = None) -> str:
    numeric = _num(value)

    if numeric is None:
        return "Veri yok"

    if decimals is None:
        decimals = 4 if abs(numeric) < 100 else 2

    text = f"{numeric:,.{decimals}f}"
    text = text.replace(",", "X").replace(".", ",").replace("X", ".")

    return f"{text} {symbol}"


def _fmt_plain_money(value: Any, symbol: str = "₺") -> str:
    return _fmt_money(value, symbol, decimals=2)


def _fmt_percent(value: Any) -> str:
    numeric = _num(value)

    if numeric is None:
        return "Veri yok"

    sign = "+" if numeric > 0 else "-" if numeric < 0 else ""
    text = f"{abs(numeric):.2f}".replace(".", ",")

    return f"{sign}%{text}"


def _badge_class(value: Any) -> str:
    numeric = _num(value, 0.0) or 0.0

    if numeric > 0:
        return "fp-first-badge-pos"

    if numeric < 0:
        return "fp-first-badge-neg"

    return "fp-first-badge-flat"


def _badge_arrow(value: Any) -> str:
    numeric = _num(value, 0.0) or 0.0

    if numeric > 0:
        return "↑"

    if numeric < 0:
        return "↓"

    return "→"


def _safe_df(value: Any) -> pd.DataFrame:
    try:
        if isinstance(value, pd.DataFrame):
            return value.copy()

        if isinstance(value, (list, tuple, dict)):
            return pd.DataFrame(value).copy()

    except Exception:
        pass

    return pd.DataFrame()


def _future_df(forecast_data: Mapping[str, Any]) -> pd.DataFrame:
    if not isinstance(forecast_data, Mapping):
        return pd.DataFrame()

    keys = [
        "gelecek_df",
        "gelecek_tablo_df",
        "gelecek_tablo",
        "future_table",
        "future_scenarios",
        "senaryo_tablosu",
    ]

    for key in keys:
        df = _safe_df(forecast_data.get(key))

        if not df.empty and "Vade" in df.columns:
            return df

    for value in forecast_data.values():
        df = _safe_df(value)

        if not df.empty and "Vade" in df.columns:
            return df

    return pd.DataFrame()


def _pick_future_row(
    forecast_data: Mapping[str, Any],
    selected_horizon: Optional[str],
) -> dict[str, Any]:
    df = _future_df(forecast_data)

    if df.empty:
        return {}

    candidates = []

    if selected_horizon:
        candidates.append(str(selected_horizon).strip())

    candidates.extend(
        [
            "1 Yıl",
            "6 Ay",
            "3 Ay",
            "1 Ay",
            "1 Hafta",
            "1 İşlem Günü",
        ]
    )

    if "Vade" in df.columns:
        normalized = df["Vade"].astype(str).str.strip().str.casefold()

        for label in candidates:
            matched = df[normalized == label.strip().casefold()]

            if not matched.empty:
                return matched.iloc[0].to_dict()

    return df.iloc[-1].to_dict()


def _model_count(row: Mapping[str, Any], forecast_data: Mapping[str, Any]) -> int | str:
    direct = _num(row.get("Konsensüs Model Sayısı", row.get("Model Sayısı")))

    if direct is not None:
        return int(direct)

    weights = forecast_data.get("model_agirliklari") if isinstance(forecast_data, Mapping) else None

    if isinstance(weights, dict):
        return len(
            [
                value
                for value in weights.values()
                if (_num(value, 0.0) or 0.0) > 0
            ]
        )

    return "—"


def _history_close_series(data: pd.DataFrame) -> pd.Series:
    if data is None or data.empty or "Close" not in data.columns:
        return pd.Series(dtype="float64")

    return pd.to_numeric(data["Close"], errors="coerce").dropna()


def _days_from_label(label: Optional[str], fallback: Optional[int] = None) -> int:
    if fallback and fallback > 0:
        return int(fallback)

    text = str(label or "").strip().casefold()

    if "hafta" in text:
        return 5

    if "1 ay" in text:
        return 21

    if "3 ay" in text:
        return 63

    if "6 ay" in text:
        return 126

    if "1 yıl" in text or "1 yil" in text:
        return 252

    if "3 yıl" in text or "3 yil" in text:
        return 756

    if "5 yıl" in text or "5 yil" in text:
        return 1260

    return 252


def _past_snapshot(
    data: pd.DataFrame,
    current_price: float,
    investment_amount: float,
    currency_rate: float,
    selected_horizon: Optional[str],
    forecast_days: Optional[int],
) -> dict[str, Any]:
    close = _history_close_series(data)
    current_native = _num(current_price)
    invested = _num(investment_amount, 0.0) or 0.0
    rate = _num(currency_rate, 1.0) or 1.0
    days = _days_from_label(selected_horizon, forecast_days)

    result = {
        "days": days,
        "past_price_display": None,
        "historical_return_percent": None,
        "same_position_past_value": None,
        "past_investment_today_value": None,
    }

    if current_native is None or current_native <= 0 or close.empty or len(close) <= days:
        return result

    past_native = _num(close.iloc[-(days + 1)])

    if past_native is None or past_native <= 0:
        return result

    result["past_price_display"] = past_native * rate
    result["historical_return_percent"] = ((current_native / past_native) - 1.0) * 100.0

    if invested > 0:
        result["same_position_past_value"] = invested * past_native / current_native
        result["past_investment_today_value"] = invested * current_native / past_native

    return result


def _past_return_rows(
    data: pd.DataFrame,
    current_price: float,
    investment_amount: float,
    currency_rate: float,
    currency_symbol: str,
) -> list[dict[str, str]]:
    close = _history_close_series(data)
    current_native = _num(current_price)
    invested = _num(investment_amount, 0.0) or 0.0
    rate = _num(currency_rate, 1.0) or 1.0

    if current_native is None or current_native <= 0 or close.empty:
        return []

    rows = []

    periods = [
        ("1 Hafta", 5),
        ("1 Ay", 21),
        ("3 Ay", 63),
        ("6 Ay", 126),
        ("1 Yıl", 252),
    ]

    for label, days in periods:
        if len(close) <= days:
            continue

        old_native = _num(close.iloc[-(days + 1)])

        if old_native is None or old_native <= 0:
            continue

        return_percent = ((current_native / old_native) - 1.0) * 100.0
        today_value = invested * current_native / old_native if invested > 0 else None

        rows.append(
            {
                "Vade": label,
                "Geçmiş Fiyat": _fmt_money(old_native * rate, currency_symbol),
                "Bugünkü Karşılığı": _fmt_plain_money(today_value, currency_symbol),
                "Getiri %": _fmt_percent(return_percent),
                "tone": "positive"
                if return_percent > 0
                else "negative"
                if return_percent < 0
                else "flat",
            }
        )

    return rows



def _render_history_table(rows: list[dict[str, str]]) -> None:
    """Geçmiş getiri tablosunu HTML kodu sızdırmadan güvenli şekilde gösterir."""
    if not rows:
        st.info("Geçmiş getiri özeti için yeterli veri bulunamadı.")
        return

    clean_rows = []

    for row in rows:
        clean_rows.append(
            {
                "Vade": row.get("Vade", "—"),
                "Geçmiş Fiyat": row.get("Geçmiş Fiyat", "—"),
                "Bugünkü Karşılığı": row.get("Bugünkü Karşılığı", "—"),
                "Getiri %": row.get("Getiri %", "—"),
            }
        )

    try:
        from components.premium_ui import render_premium_table

        render_premium_table(
            clean_rows,
            title="Geçmiş getiri özeti",
            subtitle="Seçili sermayenin farklı geçmiş vadelerde bugünkü yaklaşık karşılığını gösterir.",
        )
    except Exception:
        st.markdown("### Geçmiş getiri özeti")
        st.dataframe(
            pd.DataFrame(clean_rows),
            use_container_width=True,
            hide_index=True,
        )


