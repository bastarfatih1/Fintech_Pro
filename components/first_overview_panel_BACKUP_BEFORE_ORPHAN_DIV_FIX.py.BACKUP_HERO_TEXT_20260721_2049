def _consensus_chart(
    data: pd.DataFrame,
    current_price: float,
    currency_rate: float,
    forecast_data: Mapping[str, Any],
    forecast_days: Optional[int],
    currency_symbol: str,
) -> Optional[go.Figure]:
    close = _history_close_series(data)

    if close.empty:
        return None

    rate = _num(currency_rate, 1.0) or 1.0
    current_display = (_num(current_price) or float(close.iloc[-1])) * rate

    history = (close.iloc[-252:] * rate).astype(float)
    dates = list(history.index)
    values = list(history.values)

    route = None

    if isinstance(forecast_data, Mapping):
        for key in ["konsensus_rota", "consensus_path"]:
            value = forecast_data.get(key)

            if value is None:
                continue

            try:
                arr = np.asarray(value, dtype=float).flatten()

                if arr.size > 0:
                    route = arr
                    break

            except Exception:
                pass

    if route is not None and route.size > 0:
        max_days = int(forecast_days or min(len(route), 252))
        max_days = max(1, min(max_days, len(route)))
        last_date = pd.Timestamp(dates[-1]) if dates else pd.Timestamp.today()
        future_dates = pd.bdate_range(last_date, periods=max_days + 1)[1:]

        dates.extend(list(future_dates))
        values.extend(list(route[:max_days]))

    if not dates or not values:
        return None

    y = np.asarray(values, dtype=float)
    x = pd.to_datetime(dates)
    baseline = np.full_like(y, current_display, dtype=float)
    above = np.where(y >= current_display, y, np.nan)
    below = np.where(y < current_display, y, np.nan)

    fig = go.Figure()

    fig.add_trace(
        go.Scatter(
            x=x,
            y=baseline,
            mode="lines",
            line=dict(
                color="rgba(226,232,240,0.55)",
                width=1,
                dash="dash",
            ),
            name=f"Güncel Fiyat ({_fmt_money(current_display, currency_symbol)})",
            hoverinfo="skip",
        )
    )

    fig.add_trace(
        go.Scatter(
            x=x,
            y=above,
            mode="lines",
            line=dict(color="#22c55e", width=2.2),
            fill="tonexty",
            fillcolor="rgba(34,197,94,0.22)",
            name="Konsensüs > Güncel Fiyat",
            connectgaps=False,
        )
    )

    fig.add_trace(
        go.Scatter(
            x=x,
            y=below,
            mode="lines",
            line=dict(color="#ef4444", width=2.2),
            fill="tonexty",
            fillcolor="rgba(239,68,68,0.20)",
            name="Konsensüs < Güncel Fiyat",
            connectgaps=False,
        )
    )

    fig.add_trace(
        go.Scatter(
            x=x,
            y=y,
            mode="lines",
            line=dict(color="rgba(226,232,240,0.20)", width=1),
            name="Fiyat / Konsensüs Yolu",
            hovertemplate="%{x|%d.%m.%Y}<br>%{y:.2f}<extra></extra>",
            showlegend=False,
        )
    )

    fig.update_layout(
        height=360,
        margin=dict(l=10, r=18, t=12, b=10),
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(2,6,23,0.72)",
        font=dict(
            color="#cbd5e1",
            family="Inter, Arial, sans-serif",
        ),
        hovermode="x unified",
        legend=dict(
            orientation="h",
            yanchor="bottom",
            y=1.02,
            xanchor="center",
            x=0.5,
            bgcolor="rgba(0,0,0,0)",
            font=dict(size=11),
        ),
        xaxis=dict(
            showgrid=True,
            gridcolor="rgba(148,163,184,0.12)",
            zeroline=False,
            rangeslider=dict(visible=False),
            rangeselector=dict(
                buttons=[
                    dict(count=1, label="1A", step="month", stepmode="backward"),
                    dict(count=3, label="3A", step="month", stepmode="backward"),
                    dict(count=6, label="6A", step="month", stepmode="backward"),
                    dict(count=1, label="1Y", step="year", stepmode="backward"),
                    dict(count=2, label="2Y", step="year", stepmode="backward"),
                    dict(step="all", label="Tümü"),
                ],
                bgcolor="rgba(15,23,42,0.85)",
                activecolor="#2563eb",
                font=dict(
                    color="#e2e8f0",
                    size=11,
                ),
            ),
        ),
        yaxis=dict(
            side="right",
            showgrid=True,
            gridcolor="rgba(148,163,184,0.12)",
            zeroline=False,
            tickformat=".2f",
        ),
    )

    return fig


def render_first_overview_panel(
    data: pd.DataFrame,
    asset_name: str,
    market_symbol: str,
    current_price: float,
    investment_amount: float,
    currency_rate: float,
    currency_symbol: str,
    forecast_data: Mapping[str, Any],
    selected_horizon: Optional[str] = None,
    forecast_days: Optional[int] = None,
) -> None:
    _inject_style()

    row = _pick_future_row(forecast_data, selected_horizon)
    horizon = str(row.get("Vade") or selected_horizon or "Seçili vade")

    rate = _num(currency_rate, 1.0) or 1.0
    invested = _num(investment_amount, 0.0) or 0.0
    current_display = (_num(current_price, 0.0) or 0.0) * rate

    base_price = _num(row.get("Baz Senaryo", row.get("Tahmin")), current_display) or current_display
    bad_price = _num(row.get("Kötümser Senaryo"), base_price) or base_price
    good_price = _num(row.get("İyimser Senaryo"), base_price) or base_price

    base_return = _num(
        row.get("Nominal Getiri %"),
        ((base_price / current_display) - 1.0) * 100.0 if current_display > 0 else 0.0,
    ) or 0.0

    bad_return = _num(
        row.get("Kötümser Getiri %"),
        ((bad_price / current_display) - 1.0) * 100.0 if current_display > 0 else 0.0,
    ) or 0.0

    good_return = _num(
        row.get("İyimser Getiri %"),
        ((good_price / current_display) - 1.0) * 100.0 if current_display > 0 else 0.0,
    ) or 0.0

    bad_capital = _num(
        row.get("Kötümser Sermaye"),
        invested * (1.0 + bad_return / 100.0) if invested else None,
    )

    base_capital = _num(
        row.get("Sermaye Karşılığı"),
        invested * (1.0 + base_return / 100.0) if invested else None,
    )

    good_capital = _num(
        row.get("İyimser Sermaye"),
        invested * (1.0 + good_return / 100.0) if invested else None,
    )

    snapshot = _past_snapshot(
        data=data,
        current_price=current_price,
        investment_amount=investment_amount,
        currency_rate=currency_rate,
        selected_horizon=horizon,
        forecast_days=forecast_days,
    )

    past_price = snapshot.get("past_price_display")
    historical_return = snapshot.get("historical_return_percent")
    same_position_past_value = snapshot.get("same_position_past_value")
    past_investment_today_value = snapshot.get("past_investment_today_value")
    model_count = _model_count(row, forecast_data)

    info_html = f"""
    <div class="fp-first-info">
        <div class="fp-first-info-icon">i</div>
        <div>
            <div class="fp-first-info-title">Bu bölüm ne gösteriyor?</div>
            <div class="fp-first-info-text">
                Bu bölüm seçili varlık için güncel fiyatı, seçilen baz senaryoyu ve kısa gelecek özetini gösterir.<br>
                Ayrıca yatırımınızın {escape(horizon)} önceki duruma göre bugünkü değerini ve model konsensüsünü özetler.
            </div>
        </div>
    </div>
    """

    st.markdown(dedent(info_html).strip(), unsafe_allow_html=True)

    top_cards = f"""
    <div class="fp-first-grid-4">
        {_metric_card("Güncel Fiyat", _fmt_money(current_display, currency_symbol), market_symbol, "$")}
        {_metric_card("Baz Senaryo", _fmt_money(base_price, currency_symbol), f"{horizon} hedef", "⌖")}
        {_metric_card("Olası Getiri", _fmt_percent(base_return), f"{horizon} potansiyel", "↗")}
        {_metric_card("Konsensüse Giren Model", str(model_count), "Aktif model", "▱")}
    </div>
    """

    st.markdown(dedent(top_cards).strip(), unsafe_allow_html=True)

    st.markdown(
        '<div class="fp-first-section-title">Mevcut yatırım ve geçmiş karşılaştırması</div>',
        unsafe_allow_html=True,
    )

    invest_cards = f"""
    <div class="fp-first-grid-invest">
        {_metric_card("Yatırılan Sermaye", _fmt_plain_money(invested, currency_symbol), "", "▣", True)}
        {_metric_card("Güncel Varlık Fiyatı", _fmt_money(current_display, currency_symbol), "", "↗", True)}
        {_metric_card(f"{horizon} Önceki Fiyat", _fmt_money(past_price, currency_symbol), "", "◷", True)}
        {_metric_card("Geçmiş Getiri", _fmt_percent(historical_return), "", "↗", True)}
    </div>
    <div class="fp-first-note-strip">
        Bugünkü <strong>{escape(_fmt_plain_money(invested, currency_symbol))}</strong> değerindeki aynı pozisyon,
        {escape(horizon)} önce yaklaşık <strong>{escape(_fmt_plain_money(same_position_past_value, currency_symbol))}</strong> değerindeydi.
        O tarihte <strong>{escape(_fmt_plain_money(invested, currency_symbol))}</strong> yatırılsaydı bugünkü yaklaşık değeri
        <strong>{escape(_fmt_plain_money(past_investment_today_value, currency_symbol))}</strong> olurdu.
    </div>
    """

    st.markdown(dedent(invest_cards).strip(), unsafe_allow_html=True)

    col_scenario, col_history = st.columns([1, 1.05])

    with col_scenario:
        scenario_html = f"""
        <div>
            <div class="fp-first-section-title">{escape(horizon)} gelecek yatırım tahmini</div>
            <div class="fp-first-scenario-grid">
                {_scenario_card("Kötümser Senaryo", _fmt_plain_money(bad_capital, currency_symbol), bad_return)}
                {_scenario_card("Baz Konsensüs Tahmini", _fmt_plain_money(base_capital, currency_symbol), base_return, base=True)}
                {_scenario_card("İyimser Senaryo", _fmt_plain_money(good_capital, currency_symbol), good_return)}
            </div>
        </div>
        """

        st.markdown(dedent(scenario_html).strip(), unsafe_allow_html=True)

    with col_history:
        _render_history_table(
            _past_return_rows(
                data=data,
                current_price=current_price,
                investment_amount=investment_amount,
                currency_rate=currency_rate,
                currency_symbol=currency_symbol,
            )
        )

    st.markdown(
        """
        <div class="fp-first-chart-card">
            <div class="fp-first-chart-title">Konsensüs Grafiği</div>
            <div class="fp-first-chart-sub">Modellerin ortak tahmin görünümü</div>
        </div>
        """,
        unsafe_allow_html=True,
    )

    fig = _consensus_chart(
        data=data,
        current_price=current_price,
        currency_rate=currency_rate,
        forecast_data=forecast_data,
        forecast_days=forecast_days,
        currency_symbol=currency_symbol,
    )

    if fig is None:
        st.info("Konsensüs grafiği için yeterli veri bulunamadı.")
    else:
        try:
            from components.premium_charts import render_premium_plotly_chart

            render_premium_plotly_chart(fig, use_container_width=True)

        except Exception:
            st.plotly_chart(fig, use_container_width=True)

