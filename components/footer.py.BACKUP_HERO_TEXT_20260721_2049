def render_action_footer() -> None:
    """Alt menü ve ayrıntılı yatırım izleme listesini gösterir."""
    _inject_footer_style()

    col_refresh, col_watch, col_report, col_ai = st.columns(
        [1, 1.25, 1.1, 1.2]
    )

    with col_refresh:
        if st.button(
            "Yenile",
            key="fp_refresh",
            use_container_width=True,
        ):
            _safe_rerun()

    with col_watch:
        if st.button(
            "İzleme Listesine Ekle / Güncelle",
            key="fp_watchlist_add",
            use_container_width=True,
        ):
            _add_or_update_watchlist()

    with col_report:
        payload = _payload()

        if payload:
            try:
                from services.pdf_report_service import (
                    build_analysis_report_pdf,
                )

                pdf_bytes = build_analysis_report_pdf(payload)

                st.download_button(
                    "Rapor İndir",
                    data=pdf_bytes,
                    file_name=_build_report_filename(),
                    mime="application/pdf",
                    type="primary",
                    key="fp_download_report",
                    use_container_width=True,
                )
            except Exception as exc:
                st.button(
                    "Rapor İndir",
                    disabled=True,
                    key="fp_report_error",
                    use_container_width=True,
                )
                st.caption(f"PDF hazırlanamadı: {exc}")
        else:
            st.button(
                "Rapor İndir",
                disabled=True,
                key="fp_report_no_analysis",
                use_container_width=True,
            )

    with col_ai:
        if st.button(
            "AI Analiz Raporu",
            key="fp_ai_report",
            use_container_width=True,
        ):
            if _payload():
                st.session_state["show_ai_report_panel"] = True
                st.success(
                    "AI analiz raporu hazırlandı."
                )
            else:
                st.warning(
                    "Önce bir analiz çalıştırılmalı."
                )

    _render_watchlist_panel()
