"""Alt işlem menüsü ve ayrıntılı izleme listesi."""

from __future__ import annotations

from datetime import datetime
from html import escape
from textwrap import dedent
from typing import Any

import streamlit as st


def _safe_float(value: Any, default: float | None = None) -> float | None:
    try:
        if value is None:
            return default
        return float(value)
    except (TypeError, ValueError):
        return default


def _money(value: Any, symbol: str) -> str:
    numeric = _safe_float(value)

    if numeric is None:
        return "Veri yok"

    formatted = f"{numeric:,.2f}"
    formatted = formatted.replace(",", "X").replace(".", ",").replace("X", ".")

    return f"{formatted} {symbol}"


def _price(value: Any, symbol: str) -> str:
    return _money(value, symbol)


def _percent(value: Any) -> str:
    numeric = _safe_float(value)

    if numeric is None:
        return "Veri yok"

    sign = "+" if numeric > 0 else "-" if numeric < 0 else ""
    formatted = f"{abs(numeric):.2f}".replace(".", ",")

    return f"{sign}%{formatted}"


def _metric_delta(value: Any) -> str | None:
    """Streamlit st.metric için yönü doğru algılanan delta formatı."""
    numeric = _safe_float(value)

    if numeric is None:
        return None

    # Streamlit delta yönünü en sağlıklı İngilizce sayı formatında okuyor.
    return f"{numeric:+.2f}%"


def _safe_rerun() -> None:
    try:
        st.rerun()
    except Exception:
        try:
            st.experimental_rerun()
        except Exception:
            pass


def _payload() -> dict[str, Any]:
    payload = st.session_state.get("last_analysis_payload") or {}
    return payload if isinstance(payload, dict) else {}


def _build_report_filename() -> str:
    payload = _payload()

    symbol = str(
        payload.get("market_symbol", "analysis")
    ).replace("/", "-").replace("=", "").replace(" ", "_")

    stamp = datetime.now().strftime("%Y%m%d_%H%M")

    return f"fintech_alpha_pro_{symbol}_{stamp}.pdf"


def _build_watchlist_item() -> dict[str, Any] | None:
    payload = _payload()

    symbol = str(payload.get("market_symbol") or "").strip()

    if not symbol:
        return None

    snapshot = payload.get("watchlist_snapshot") or {}

    if not isinstance(snapshot, dict):
        snapshot = {}

    currency_symbol = str(
        payload.get("currency_symbol") or "₺"
    )

    horizon = str(
        snapshot.get("selected_horizon")
        or payload.get("forecast_label")
        or "Seçili vade"
    )

    return {
        "record_key": (
            f"{symbol}|{horizon}|{currency_symbol}"
        ),
        "asset_name": str(
            payload.get("asset_name") or "Seçili varlık"
        ),
        "market_symbol": symbol,
        "currency_symbol": currency_symbol,
        "selected_horizon": horizon,
        "forecast_days": snapshot.get(
            "forecast_days",
            payload.get("forecast_days"),
        ),
        "invested_capital": snapshot.get(
            "invested_capital",
            payload.get("investment_amount"),
        ),
        "current_price": snapshot.get("current_price"),
        "past_price": snapshot.get("past_price"),
        "same_position_past_value": snapshot.get(
            "same_position_past_value"
        ),
        "past_investment_today_value": snapshot.get(
            "past_investment_today_value"
        ),
        "historical_return_percent": snapshot.get(
            "historical_return_percent"
        ),
        "future_pessimistic_capital": snapshot.get(
            "future_pessimistic_capital"
        ),
        "future_base_capital": snapshot.get(
            "future_base_capital"
        ),
        "future_optimistic_capital": snapshot.get(
            "future_optimistic_capital"
        ),
        "future_base_return_percent": snapshot.get(
            "future_base_return_percent"
        ),
        "updated_at": datetime.now().strftime(
            "%d.%m.%Y %H:%M"
        ),
    }


def _add_or_update_watchlist() -> None:
    item = _build_watchlist_item()

    if item is None:
        st.warning(
            "İzleme listesine eklemek için önce analiz çalıştırılmalı."
        )
        return

    watchlist = list(st.session_state.get("watchlist", []))
    record_key = item["record_key"]

    updated = False
    cleaned_watchlist = []

    for existing in watchlist:
        if not isinstance(existing, dict):
            continue

        if existing.get("record_key") == record_key:
            cleaned_watchlist.append(item)
            updated = True
        else:
            cleaned_watchlist.append(existing)

    if not updated:
        cleaned_watchlist.append(item)

    st.session_state["watchlist"] = cleaned_watchlist

    if updated:
        st.success(
            "İzleme listesindeki yatırım özeti güncellendi."
        )
    else:
        st.success(
            "Varlık ve yatırım senaryosu izleme listesine eklendi."
        )


def _remove_watchlist_item(record_key: str) -> None:
    watchlist = st.session_state.get("watchlist", [])

    st.session_state["watchlist"] = [
        item
        for item in watchlist
        if isinstance(item, dict)
        and item.get("record_key") != record_key
    ]

    _safe_rerun()



def _render_watchlist_card(item: dict[str, Any], index: int) -> None:
    asset_name = str(item.get("asset_name") or "Seçili varlık")
    symbol = str(item.get("market_symbol") or "—")
    horizon = str(item.get("selected_horizon") or "—")
    currency = str(item.get("currency_symbol") or "₺")
    updated_at = str(item.get("updated_at") or "—")

    invested = _money(item.get("invested_capital"), currency)
    current_price = _price(item.get("current_price"), currency)
    past_price = _price(item.get("past_price"), currency)

    past_position = _money(
        item.get("same_position_past_value"),
        currency,
    )
    past_investment_today = _money(
        item.get("past_investment_today_value"),
        currency,
    )

    historical_return = _percent(
        item.get("historical_return_percent")
    )

    future_bad = _money(
        item.get("future_pessimistic_capital"),
        currency,
    )
    future_base = _money(
        item.get("future_base_capital"),
        currency,
    )
    future_good = _money(
        item.get("future_optimistic_capital"),
        currency,
    )
    future_return = _percent(
        item.get("future_base_return_percent")
    )

    with st.container(border=True):
        top_left, top_right = st.columns([3, 1])

        with top_left:
            st.markdown(f"### {asset_name}")
            st.caption(f"{symbol} · Seçilen vade: {horizon}")

        with top_right:
            st.caption("Son güncelleme")
            st.markdown(f"**{updated_at}**")

        st.markdown("#### Mevcut yatırım ve geçmiş karşılaştırması")

        c1, c2, c3, c4 = st.columns(4)

        with c1:
            st.metric("Yatırılan Sermaye", invested)

        with c2:
            st.metric("Güncel Varlık Fiyatı", current_price)

        with c3:
            st.metric(f"{horizon} Önceki Fiyat", past_price)

        with c4:
            st.metric("Geçmiş Getiri", historical_return)

        st.info(
            f"Bugünkü {invested} değerindeki aynı pozisyon, "
            f"{horizon} önce yaklaşık {past_position} değerindeydi. "
            f"O tarihte {invested} yatırılsaydı bugünkü yaklaşık değeri "
            f"{past_investment_today} olurdu."
        )

        st.markdown(f"#### {horizon} gelecek yatırım tahmini")

        s1, s2, s3 = st.columns(3)

        with s1:
            st.metric("Kötümser Senaryo", future_bad)

        with s2:
            st.metric(
                "Baz Konsensüs Tahmini",
                future_base,
                delta=_metric_delta(item.get("future_base_return_percent")),
            )

        with s3:
            st.metric("İyimser Senaryo", future_good)

        remove_col, _ = st.columns([1, 3])

        with remove_col:
            if st.button(
                "Kaydı Sil",
                key=f"fp_remove_watch_{index}_{item.get('record_key')}",
                use_container_width=True,
            ):
                _remove_watchlist_item(
                    str(item.get("record_key"))
                )


def _render_watchlist_panel() -> None:
    watchlist = [
        item
        for item in st.session_state.get("watchlist", [])
        if isinstance(item, dict)
    ]

    if not watchlist:
        st.markdown(
            """
            <div class="fp-watch-empty">
                İzleme listesi boş. Analiz yaptıktan sonra seçili
                varlığı yatırım senaryosuyla birlikte ekleyebilirsin.
            </div>
            """,
            unsafe_allow_html=True,
        )
        return

    with st.expander(
        f"İzleme Listem · {len(watchlist)} yatırım senaryosu",
        expanded=True,
    ):
        for index, item in enumerate(watchlist):
            _render_watchlist_card(item, index)

        st.divider()

        if st.button(
            "İzleme Listesinin Tamamını Temizle",
            key="fp_clear_watchlist",
            use_container_width=True,
        ):
            st.session_state["watchlist"] = []
            _safe_rerun()


