def render_first_sidebar() -> str:
    inject_first_app_shell_css()

    with st.sidebar:
        st.markdown(
            """
            <div class="fp-shell-logo">
                <div class="fp-shell-logo-main">FIRST</div>
                <div class="fp-shell-logo-sub">ANALYTICS</div>
            </div>
            """,
            unsafe_allow_html=True,
        )

        st.markdown(
            """
            <div class="fp-shell-status">
                <strong>Fintech Alpha Pro</strong>
                Kurumsal risk terminali
            </div>
            """,
            unsafe_allow_html=True,
        )

        st.markdown(
            '<div class="fp-shell-section-label">Analiz Menüsü</div>',
            unsafe_allow_html=True,
        )

        labels = [item[0] for item in NAV_ITEMS]

        default_page = st.session_state.get("fp_active_page", "Genel Bakış")

        if default_page not in labels:
            default_page = "Genel Bakış"

        selected = st.radio(
            "Sayfa seçimi",
            labels,
            index=labels.index(default_page),
            key="fp_active_page",
            label_visibility="collapsed",
        )

        st.markdown(
            """
            <div class="fp-shell-plan">
                <div class="fp-shell-plan-title">Pro Plan</div>
                <div class="fp-shell-plan-sub">Premium</div>
                <div class="fp-shell-plan-sub" style="margin-top:10px;">Kalan analiz hakkı</div>
                <div class="fp-shell-plan-title" style="font-size:.96rem;">142 / 200</div>
                <div class="fp-shell-progress"><div></div></div>
                <div class="fp-shell-plan-btn">Planı Yönet</div>
            </div>
            """,
            unsafe_allow_html=True,
        )

    return selected


def render_active_page_header(active_page: str) -> None:
    subtitle = dict(NAV_ITEMS).get(active_page, "")

    st.markdown(
        f"""
        <div class="fp-shell-active-page">
            <div class="fp-shell-active-title">{active_page}</div>
            <div class="fp-shell-active-sub">{subtitle}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )
