def _nav_label(icon: str, title: str, active: bool) -> str:
    prefix = "▸" if active else " "
    return f"{prefix} {icon}  {title}"


def render_first_sidebar() -> str:
    inject_first_app_shell_css()

    if "fp_active_page" not in st.session_state:
        st.session_state["fp_active_page"] = "Genel Bakış"

    active_page = st.session_state.get("fp_active_page", "Genel Bakış")

    with st.sidebar:
        st.markdown(
            """
            <div class="fp-shell-logo">
                <div class="fp-shell-logo-main">FIRST</div>
                <div class="fp-shell-logo-sub">ANALYTICS</div>
            </div>
            """,
            unsafe_allow_html=True,
        )

        st.markdown(
            """
            <div class="fp-shell-status">
                <strong>Fintech Alpha Pro</strong>
                Kurumsal risk terminali
            </div>
            """,
            unsafe_allow_html=True,
        )

        st.markdown(
            f"""
            <div class="fp-active-page-pill">
                <strong>{active_page}</strong>
                Sol menüden analiz bölümleri arasında geçiş yapılır.
            </div>
            """,
            unsafe_allow_html=True,
        )

        st.markdown(
            '<div class="fp-shell-section-label">Analiz Menüsü</div>',
            unsafe_allow_html=True,
        )

        for title, subtitle, icon in NAV_ITEMS:
            is_active = title == active_page

            clicked = st.button(
                _nav_label(icon, title, is_active),
                key=f"fp_nav_{title}",
                type="primary" if is_active else "secondary",
                use_container_width=True,
            )

            if clicked:
                st.session_state["fp_active_page"] = title
                return title

        st.markdown(
            """
            <div class="fp-shell-plan">
                <div class="fp-shell-plan-title">Pro Plan</div>
                <div class="fp-shell-plan-sub">Premium</div>
                <div class="fp-shell-plan-sub" style="margin-top:10px;">Kalan analiz hakkı</div>
                <div class="fp-shell-plan-title" style="font-size:.96rem;">142 / 200</div>
                <div class="fp-shell-progress"><div></div></div>
                <div class="fp-shell-plan-btn">Planı Yönet</div>
            </div>
            """,
            unsafe_allow_html=True,
        )

    return st.session_state.get("fp_active_page", "Genel Bakış")


def render_active_page_header(active_page: str) -> None:
    subtitle = ""

    for title, item_subtitle, _ in NAV_ITEMS:
        if title == active_page:
            subtitle = item_subtitle
            break

    st.markdown(
        f"""
        <div class="fp-shell-active-page">
            <div class="fp-shell-active-title">{active_page}</div>
            <div class="fp-shell-active-sub">{subtitle}</div>
        </div>
        """,
        unsafe_allow_html=True,
    )
