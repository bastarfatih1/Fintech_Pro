def render_action_footer() -> None:
    """Alt işlem menüsünü çalışan, görünür ve tutarlı kontrollerle gösterir."""
    _inject_footer_style()

    st.markdown('<div class="fp-action-shell">', unsafe_allow_html=True)

    col_refresh, col_watch, col_report, col_ai = st.columns([1, 1.25, 1.15, 1.25])

    with col_refresh:
        if st.button("Yenile", key="fp_refresh", use_container_width=True):
            _safe_rerun()

    with col_watch:
        if st.button("İzleme Listesine Ekle", key="fp_watchlist_add", use_container_width=True):
            _add_to_watchlist()

    with col_report:
        payload = st.session_state.get("last_analysis_payload")

        if payload:
            try:
                from services.pdf_report_service import build_analysis_report_pdf

                pdf_bytes = build_analysis_report_pdf(payload)

                st.download_button(
                    "Rapor İndir",
                    data=pdf_bytes,
                    file_name=_build_report_filename(),
                    mime="application/pdf",
                    type="primary",
                    key="fp_download_report",
                    use_container_width=True,
                )
            except Exception as exc:
                st.button("Rapor İndir", key="fp_report_disabled_error", disabled=True, use_container_width=True)
                st.caption(f"PDF hazırlanamadı: {exc}")
        else:
            st.button("Rapor İndir", key="fp_report_disabled_no_analysis", disabled=True, use_container_width=True)

    with col_ai:
        if st.button("AI Analiz Raporu", key="fp_ai_report", use_container_width=True):
            if st.session_state.get("last_analysis_payload"):
                st.session_state["show_ai_report_panel"] = True
                st.success("AI analiz raporu hazırlandı. AI Haberler veya Analiz Sonuçları sekmesini kontrol et.")
            else:
                st.warning("Önce bir analiz çalıştırılmalı.")

    _render_watchlist_panel()

    st.markdown("</div>", unsafe_allow_html=True)
