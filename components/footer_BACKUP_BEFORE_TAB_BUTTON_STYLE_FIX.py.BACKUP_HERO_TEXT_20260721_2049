"""
Alt işlem menüsü.

Bu sürüm:
- Rapor İndir butonunu diğer butonlarla aynı premium stile yaklaştırır.
- İzleme listesine eklenen varlıkları aynı bölümde görünür hale getirir.
- HTML button yerine gerçek Streamlit button / download_button kullanır.
"""

from __future__ import annotations

from datetime import datetime
from typing import Any

import streamlit as st


def _safe_rerun() -> None:
    try:
        st.rerun()
    except Exception:
        try:
            st.experimental_rerun()
        except Exception:
            pass


def _payload() -> dict[str, Any]:
    data = st.session_state.get("last_analysis_payload") or {}
    return data if isinstance(data, dict) else {}


def _pick(data: dict[str, Any], *keys: str, default: Any = "—") -> Any:
    for key in keys:
        value = data.get(key)
        if value not in (None, "", [], {}):
            return value
    return default


def _build_report_filename() -> str:
    payload = _payload()
    symbol = str(
        _pick(
            payload,
            "market_symbol",
            "symbol",
            "ticker",
            "asset_symbol",
            default="analysis",
        )
    )
    symbol = symbol.replace("/", "-").replace("=", "").replace(" ", "_")
    stamp = datetime.now().strftime("%Y%m%d_%H%M")
    return f"fintech_alpha_pro_{symbol}_{stamp}.pdf"


def _current_watch_item() -> dict[str, Any]:
    payload = _payload()

    return {
        "Varlık": _pick(
            payload,
            "asset_name",
            "asset_label",
            "selected_asset",
            "varlik_adi",
            "name",
            default="Seçili varlık",
        ),
        "Sembol": _pick(
            payload,
            "market_symbol",
            "symbol",
            "ticker",
            "asset_symbol",
            default="—",
        ),
        "Vade": _pick(
            payload,
            "forecast_label",
            "selected_horizon_label",
            "horizon_label",
            "projection_horizon",
            "selected_horizon",
            "forecast_days",
            default="—",
        ),
        "Para Birimi": _pick(
            payload,
            "currency_symbol",
            "display_currency",
            "currency",
            "base_currency",
            default="—",
        ),
        "Eklenme": datetime.now().strftime("%Y-%m-%d %H:%M"),
    }


def _add_to_watchlist() -> None:
    item = _current_watch_item()

    if item["Sembol"] == "—":
        st.warning("İzleme listesine eklemek için önce analiz çalıştırılmalı.")
        return

    watchlist = list(st.session_state.get("watchlist", []))

    already_exists = any(
        str(row.get("Sembol")) == str(item["Sembol"]) and str(row.get("Vade")) == str(item["Vade"])
        for row in watchlist
        if isinstance(row, dict)
    )

    if already_exists:
        st.info("Bu varlık aynı vadeyle zaten izleme listesinde.")
        return

    watchlist.append(item)
    st.session_state["watchlist"] = watchlist
    st.success("Varlık izleme listesine eklendi.")


def _render_watchlist_panel() -> None:
    watchlist = st.session_state.get("watchlist", [])

    if not watchlist:
        st.markdown(
            """
            <div class="fp-watchlist-empty">
                İzleme listesi boş. Bir analiz yaptıktan sonra “İzleme Listesine Ekle” butonuyla varlık ekleyebilirsin.
            </div>
            """,
            unsafe_allow_html=True,
        )
        return

    with st.expander(f"İzleme Listem · {len(watchlist)} varlık", expanded=False):
        try:
            from components.premium_ui import render_premium_table

            render_premium_table(
                watchlist,
                title="İzleme Listesi",
                subtitle="Eklediğin varlıklar burada görünür. Bu liste tarayıcı oturumu içinde saklanır.",
            )
        except Exception:
            st.dataframe(watchlist, use_container_width=True, hide_index=True)

        if st.button("İzleme Listesini Temizle", key="fp_clear_watchlist", use_container_width=True):
            st.session_state["watchlist"] = []
            st.success("İzleme listesi temizlendi.")
            _safe_rerun()


