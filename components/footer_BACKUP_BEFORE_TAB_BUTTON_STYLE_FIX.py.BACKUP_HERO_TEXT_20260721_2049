            border-radius: 20px;
            background:
                radial-gradient(circle at left, rgba(14, 165, 233, 0.20), transparent 34%),
                linear-gradient(135deg, rgba(2, 6, 23, 0.97), rgba(15, 23, 42, 0.94));
            box-shadow: 0 -16px 38px rgba(2, 6, 23, 0.42);
        }

        .fp-watchlist-empty {
            margin: 8px 0 4px 0;
            padding: 10px 12px;
            border-radius: 14px;
            color: rgba(226, 232, 240, 0.78);
            background: rgba(15, 23, 42, 0.55);
            border: 1px solid rgba(148, 163, 184, 0.16);
            font-size: 0.86rem;
        }

        div.stButton > button,
        div.stDownloadButton > button {
